rules_version = '2';

// ============================================================
// War of the Sphinx — Firestore rules
//
// All writes are performed by the backend (Express on Railway) using
// firebase-admin, which bypasses these rules by design. Browser clients
// can therefore have write access denied universally.
//
// Reads are scoped: public content (gallery_images, site_content, content)
// remains readable by anyone; private collections (email_subscribers,
// sessions, visitor_sessions) are denied all client access.
//
// To deploy locally:
//   firebase deploy --only firestore:rules --project wots-platform-11435
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Public gallery — anyone can browse, only backend writes
    match /gallery_images/{imageId} {
      allow read: if true;
      allow write: if false;
    }

    // Homepage CMS — anyone can read (published content), only backend writes
    match /site_content/{sectionId} {
      allow read: if true;
      allow write: if false;
    }

    // Lore / content library — public read, backend writes
    match /content/{contentId} {
      allow read: if true;
      allow write: if false;
    }

    // Email subscribers — private. All access goes through the backend
    // POST /api/subscribe (admin SDK) and admin-only aggregation endpoints.
    match /email_subscribers/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // Chat sessions — private. Backend reads/writes via admin SDK.
    match /sessions/{sessionId} {
      allow read: if false;
      allow write: if false;
    }

    // Visitor analytics — private. Written by /api/track-visit, read via /api/analytics.
    match /visitor_sessions/{visitId} {
      allow read: if false;
      allow write: if false;
    }

    // Default deny for any collection not listed above.
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
